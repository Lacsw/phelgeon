(ns tests\core-test
  (:require phel\test :refer [deftest is])
  (:require phelgeon\core :as core)
  (:require tests\helpers\fixtures :as f)
  (:require phelgeon\content :as ct))

(deftest parse-input-explore-directions
  (is (= :north (core/parse-input "n" :explore)))
  (is (= :south (core/parse-input "s" :explore)))
  (is (= :east  (core/parse-input "e" :explore)))
  (is (= :west  (core/parse-input "w" :explore))))

(deftest parse-input-explore-meta
  (is (= :inventory (core/parse-input "i" :explore)))
  (is (= :quit      (core/parse-input "q" :explore)))
  (is (= :yes       (core/parse-input "y" :explore)))
  (is (= :noop      (core/parse-input "x" :explore)))
  (is (= :noop      (core/parse-input ""  :explore)))
  (is (= :noop      (core/parse-input nil :explore))))

(deftest parse-input-combat
  (is (= :attack     (core/parse-input "a" :combat)))
  (is (= :flee       (core/parse-input "f" :combat)))
  (is (= :use-potion (core/parse-input "u" :combat)))
  (is (= :use-bomb   (core/parse-input "b" :combat)))
  (is (= :noop       (core/parse-input "z" :combat))))

(deftest parse-input-inventory
  (is (= :slot-1 (core/parse-input "1" :inventory)))
  (is (= :slot-2 (core/parse-input "2" :inventory)))
  (is (= :back   (core/parse-input "b" :inventory)))
  (is (= :noop   (core/parse-input "x" :inventory))))

(deftest parse-input-prompt-modes
  (is (= :enter (core/parse-input "anything" :intro)))
  (is (= :enter (core/parse-input ""         :gameover)))
  (is (= :enter (core/parse-input "k"        :victory)))
  (is (= :enter (core/parse-input "j"        :quit))))

(deftest parse-input-normalization
  ;; Trims whitespace, lowercases, takes first char.
  (is (= :north (core/parse-input "  N\n" :explore)))
  (is (= :north (core/parse-input "NORTH" :explore)))
  (is (= :attack (core/parse-input " A " :combat))))

(deftest parse-input-ignores-escape-sequences
  ;; Regression for commit 41ded29: arrow keys / mouse wheel emit ESC[A etc.
  ;; The first byte after trim is "[" (ESC stripped by trim? no — ESC is 0x1b, not whitespace).
  ;; Actual first char is the ESC byte. Either way the result must be :noop, not a stray command.
  (is (= :noop (core/parse-input "\e[A" :explore)))
  (is (= :noop (core/parse-input "\e[B" :combat))))

(deftest log-stays-bounded
  ;; Drive many "no exit" log entries and assert log never exceeds MAX-LOG-LINES.
  (let [s0 (f/explore-state)
        ;; The :entrance has only :north exit, so :south/:east/:west all log "no exit"
        steps [:south :east :west :south :east :west :south :east :west :south]
        final (reduce (fn [s cmd] (core/step s cmd)) s0 steps)]
    (is (<= (count (:log final)) ct/MAX-LOG-LINES))
    (is (> (count (:log final)) 0))))

(deftest log-empty-does-not-crash
  ;; Fresh state has empty log; first failing move appends one line, no crash.
  (let [s0 (f/explore-state)
        s1 (core/step s0 :south)]
    (is (= 1 (count (:log s1))))))

(deftest inventory-mode-toggle
  (let [s0 (f/explore-state)
        s1 (core/step s0 :inventory)
        s2 (core/step s1 :back)]
    (is (= :inventory (:mode s1)))
    (is (= :explore   (:mode s2)))))

(deftest use-potion-from-inventory-heals
  ;; Player at hp 5 with max-hp 100 (override fixture). POTION-HEAL is 30 → exact 35.
  ;; This is the "partial heal" path; the cap path is covered by use-potion-caps-at-max-hp.
  (let [s0 (-> (f/explore-state)
               (assoc-in [:player :max-hp] 100)
               (assoc-in [:player :hp] 5)
               (f/with-potion 1)
               (assoc :mode :inventory))
        s1 (core/step s0 :slot-1)]
    (is (= :explore (:mode s1)) "Returns to explore after using potion.")
    (is (= (+ 5 ct/POTION-HEAL) (get-in s1 [:player :hp]))
        "HP increased by exactly POTION-HEAL.")
    (is (= 1 (get-in s1 [:player :potions-used])))
    (is (= 0 (count (get-in s1 [:player :inventory]))) "Potion consumed.")))

(deftest use-potion-caps-at-max-hp
  ;; Player already at full HP — heal should be 0 net but potion still consumed.
  (let [s0 (-> (f/explore-state)
               (f/with-potion 1)
               (assoc :mode :inventory))
        s1 (core/step s0 :slot-1)]
    (is (= 30 (get-in s1 [:player :hp])))
    (is (= 0 (count (get-in s1 [:player :inventory]))))))

(deftest use-potion-with-no-potion-noops
  (let [s0 (assoc (f/explore-state) :mode :inventory)
        s1 (core/step s0 :slot-1)]
    ;; mode stays :inventory because the use-handler logs and does NOT flip mode.
    (is (= :inventory (:mode s1)))
    (is (> (count (:log s1)) 0) "Logs a 'no potions' line.")
    (is (= 0 (get-in s1 [:player :potions-used])) "Counter not incremented on no-op.")
    (is (= 30 (get-in s1 [:player :hp])) "HP unchanged.")))

(deftest attack-kills-weak-enemy
  ;; Enemy hp 1 → any positive damage kills it.
  (let [s0 (f/combat-state [(f/weak-goblin)])
        s1 (core/step s0 :attack)]
    (is (= :explore (:mode s1)) "Mode flips back to explore after killing only enemy.")
    (is (nil? (:combat s1)) "Combat cleared.")
    (is (= 1 (get-in s1 [:player :kills])))
    (is (:cleared (get-in s1 [:rooms :combat-room])) "Room marked cleared.")))

(deftest attack-tracks-biggest-hit
  (let [s0 (f/combat-state [(f/weak-goblin)])
        s1 (core/step s0 :attack)]
    (is (> (get-in s1 [:player :biggest-hit]) 0))))

(deftest fatal-incoming-damage-flips-to-gameover
  ;; Player hp 1 vs brute (attack 99). Player attacks → enemy doesn't die (hp 99) →
  ;; enemy turn fires → player dies.
  (let [s0 (-> (f/combat-state [(f/brute)])
               (assoc-in [:player :hp] 1))
        s1 (core/step s0 :attack)]
    (is (= :gameover (:mode s1)))))

(deftest combat-with-multiple-enemies-stays-in-combat
  ;; Two weak goblins; first attack kills one, but second still alive.
  (let [s0 (f/combat-state [(f/weak-goblin) (f/weak-goblin)])
        s1 (core/step s0 :attack)]
    (is (= :combat (:mode s1)) "Still in combat with one alive.")
    (is (= 1 (get-in s1 [:player :kills])))
    (is (= 1 (count (filter (fn [e] (> (:hp e) 0))
                            (get-in s1 [:combat :enemies]))))
        "One enemy still alive.")))

(deftest use-potion-in-combat-consumes-and-triggers-enemy-turn
  ;; Bump max-hp so the cap doesn't mask whether enemy-turn ran.
  ;; Net hp = before + POTION-HEAL - enemy-dmg; enemy-dmg >= 1 so hp < before+POTION-HEAL.
  (let [s0 (-> (f/combat-state [(f/weak-goblin)])
               (assoc-in [:player :max-hp] 100)
               (assoc-in [:player :hp] 5)
               (f/with-potion 1))
        s1 (core/step s0 :use-potion)
        hp-after (get-in s1 [:player :hp])]
    (is (= 0 (count (get-in s1 [:player :inventory]))))
    (is (= 1 (get-in s1 [:player :potions-used])))
    (is (> hp-after 5) "Net HP positive after potion + enemy attack.")
    (is (< hp-after (+ 5 ct/POTION-HEAL))
        "Enemy turn fired — final hp lower than full-heal-only would yield.")))

(deftest use-bomb-instakills-and-tracks-kill
  (let [s0 (-> (f/combat-state [(f/brute)])
               (update-in [:player :inventory] conj :bomb))
        s1 (core/step s0 :use-bomb)]
    (is (= :explore (:mode s1)))
    (is (= 1 (get-in s1 [:player :kills])))
    (is (= 0 (count (get-in s1 [:player :inventory]))))))

(deftest flee-result-is-consistent
  ;; weak-goblin atk 1 + player hp 30 => player cannot die on flee failure,
  ;; so :gameover is not a reachable outcome. Mode is exactly one of {:explore, :combat}.
  ;; Either branch must always append a log line.
  (let [s0 (f/combat-state [(f/weak-goblin)])
        s1 (core/step s0 :flee)]
    (is (or (= :explore (:mode s1))
            (= :combat  (:mode s1)))
        "Mode lands in success (:explore) or failure (:combat); :gameover unreachable here.")
    (is (> (count (:log s1)) (count (:log s0)))
        "Flee always appends a log line.")
    (is (= (= :explore (:mode s1)) (nil? (:combat s1)))
        "Combat is nil iff flee succeeded.")))

(deftest move-valid-direction-updates-current
  (let [s0 (f/explore-state)
        s1 (core/step s0 :north)]
    (is (= :combat-room (:current s1)))
    (is (contains? (:visited s1) :combat-room))
    (is (= :south (:from-dir s1)) "from-dir is opposite of move direction.")))

(deftest move-invalid-direction-keeps-room-and-logs
  (let [s0 (f/explore-state)
        s1 (core/step s0 :south)]
    (is (= :entrance (:current s1)))
    (is (> (count (:log s1)) (count (:log s0))) "Logged 'no exit'.")))

(deftest move-into-uncleared-combat-room-enters-combat
  ;; Set combat-room :cleared false and give it an enemy.
  (let [s0 (-> (f/explore-state)
               (assoc-in [:rooms :combat-room :cleared] false)
               (assoc-in [:rooms :combat-room :enemies] [(f/weak-goblin)]))
        s1 (core/step s0 :north)]
    (is (= :combat (:mode s1)))
    (is (= 1 (count (get-in s1 [:combat :enemies]))))))

(deftest move-into-treasure-applies-loot-and-clears
  (let [s0 (f/explore-state-with-room (f/treasure-room))
        s1 (core/step s0 :north)]
    (is (= 10 (get-in s1 [:player :gold])))
    (is (:cleared (get-in s1 [:rooms :treasure-room])))
    (is (= :explore (:mode s1)))))

(deftest move-into-rest-room-heals-and-clears
  (let [s0 (-> (f/explore-state-with-room (f/rest-room))
               (assoc-in [:player :hp] 10))
        s1 (core/step s0 :north)]
    (is (> (get-in s1 [:player :hp]) 10))
    (is (<= (get-in s1 [:player :hp]) 30))
    (is (:cleared (get-in s1 [:rooms :rest-room])))))

(deftest move-into-exit-sets-pending-descend
  (let [s0 (f/explore-state)
        ;; Walk north into combat-room (already cleared in default fixture),
        ;; then north again into exit.
        s1 (core/step s0 :north)
        s2 (core/step s1 :north)]
    (is (:pending-descend s2))))

(deftest descend-confirm-advances-floor
  (let [s0 (-> (f/explore-state)
               (assoc :pending-descend true)
               (assoc :floor 1))
        s1 (core/step s0 :yes)]
    (is (= 2 (:floor s1)))
    (is (not (:pending-descend s1)))
    (is (= :entrance (:current s1)))))

(deftest descend-cancel-with-north-clears-pending
  (let [s0 (-> (f/explore-state)
               (assoc :pending-descend true))
        s1 (core/step s0 :north)]
    (is (not (:pending-descend s1)))
    (is (= 1 (:floor s1)) "Floor unchanged.")))

(deftest quit-confirmation-flow
  (let [s0 (f/explore-state)
        s1 (core/step s0 :quit)        ; ask for confirmation
        s2 (core/step s1 :yes)]        ; confirm
    (is (:pending-quit s1))
    (is (= :quit (:mode s2)))))

(deftest quit-cancel-with-second-q
  (let [s0 (f/explore-state)
        s1 (core/step s0 :quit)
        s2 (core/step s1 :quit)]
    (is (not (:pending-quit s2)))))
