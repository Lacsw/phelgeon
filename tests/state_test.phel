(ns tests\state-test
  (:require phel\test :refer [deftest is])
  (:require phelgeon\core :as core)
  (:require phelgeon\content :as ct)
  (:require tests\helpers\fixtures :as f))

(defn- play
  "Reduce a sequence of cmds through step, starting from `s0`."
  [s0 cmds]
  (reduce (fn [s c] (core/step s c)) s0 cmds))

(deftest intro-dismisses-on-any-input
  (let [s0 (assoc (f/explore-state) :mode :intro)
        s1 (core/step s0 :enter)]
    (is (= :explore (:mode s1)))))

(deftest full-combat-encounter-returns-to-explore
  ;; Walk into a populated combat room, kill the only enemy, land in explore.
  (let [s0 (-> (f/explore-state)
               (assoc-in [:rooms :combat-room :cleared] false)
               (assoc-in [:rooms :combat-room :enemies] [(f/weak-goblin)]))
        s-final (play s0 [:north :attack])]
    (is (= :explore (:mode s-final)))
    (is (:cleared (get-in s-final [:rooms :combat-room])))
    (is (= :combat-room (:current s-final)))))

(deftest gameover-locks-state-from-mutating-mode
  ;; Once :gameover, NO command should mutate state — it's an absorbing terminal.
  (let [s0 (-> (f/combat-state [(f/brute)])
               (assoc-in [:player :hp] 1))
        s1 (core/step s0 :attack)        ; player dies
        s2 (core/step s1 :attack)
        s3 (core/step s2 :north)]
    (is (= :gameover (:mode s1)))
    (is (= s1 s2) "Post-gameover :attack must not mutate state.")
    (is (= s1 s3) "Post-gameover :north must not mutate state.")))

(deftest log-stays-bounded-across-long-run
  ;; 15 invalid moves; log must still be capped at MAX-LOG-LINES.
  (let [s0 (f/explore-state)
        cmds (vec (for [_ :range [0 15]] :south))
        s-final (play s0 cmds)]
    (is (<= (count (:log s-final)) ct/MAX-LOG-LINES))))

(deftest parse-input-levelup-mode
  (is (= :pick-hp  (core/parse-input "a" :levelup)))
  (is (= :pick-atk (core/parse-input "b" :levelup)))
  (is (= :pick-def (core/parse-input "c" :levelup)))
  (is (= :noop     (core/parse-input "x" :levelup))))
